{"blocks":[{"type":"codeTool","data":{"codeData":{"value":"neo4jQueryToTable =async (query)=> {\n  let res = await gxr.neo4j(query, {saveToGraph: false})\n\n  return neo4jTableResultToJson(res)\n  let arr= res.data\n  arr.shift()\n  return arr.map(\n    elem=>({\n      label: elem[0][0],\n      count: elem[1].low\n  }))\n}","pinCode":false,"dname":"3930a7fa-88bf-49b7-bcf9-e642604b607d","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"function neo4jTableResultToJson(result) {\n  if (!result || !Array.isArray(result.data) || result.data.length < 2) {\n    return [];\n  }\n\n  const headers = result.data[0]; // first row: column names\n  const rows = result.data.slice(1); // remaining rows: values\n\n  return rows.map(row => {\n    const obj = {};\n    for (let i = 0; i < headers.length; i++) {\n      obj[headers[i]] = unpackNeoInt(row[i]);\n    }\n    return obj;\n  });\n}\n","pinCode":false,"dname":"5ee30880-69ec-4a9b-9834-ba7306faf2b9","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"\nfunction unpackNeoInt(val) {\n  // Neo4j integer objects from browser (not neo4j-driver)\n  if (val && typeof val === 'object' && 'low' in val && 'high' in val) {\n    // Handles large numbers correctly\n    return val.high * 2 ** 32 + val.low;\n  }\n  return val;\n}","pinCode":false,"dname":"85a02a93-d75b-462d-83e4-06e67e71c88b","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"sleep = async (ms)=>{\n  return new Promise(resolve => setTimeout(resolve, ms))\n}","pinCode":false,"dname":"18416841-6e1e-4fa2-a672-78949f63ac59","codeMode":"javascript2"}}}],"version":"2.19.1"}