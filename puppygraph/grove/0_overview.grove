{"blocks":[{"type":"codeTool","data":{"codeData":{"value":"md`### Puppygraph Security Graph Demo. \nThis demo showcases how to analyze and visualize network security configurations within a cloud environment using PuppyGraph's powerful graph querying capabilities.\n\nBy modeling the network infrastructure as a graph, users can identify potential security risks, such as:\n\n* Public IP addresses exposed to the internet\n* Network interfaces not protected by any security group\n* Roles granted excessive access permissions\n* Security groups with overly permissive ingress rules\n\n<a href=\"https://github.com/puppygraph/puppygraph-getting-started/tree/main/use-case-demos/cloud-security-graph-demo\" target=\"_blank\">Github Repository</a>\n`","pinCode":false,"dname":"b8823d14-fb0e-4a2f-b8f1-5be9f2266759","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"md `##### Display Schema\nCypher:  \n\\`\\`\\`\n:schema\n\\`\\`\\`\n`","pinCode":false,"dname":"f99998b0-9486-44e0-aa75-76502bd77a36","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"Inputs.button(\"Show Schema\", {reduce: async ()=>{\n  await gxr.query(\":schema\")\n  await gxr.sleep(2000)\n  gxr.nodes().array.forEach(n=>n.properties.label = n.category)\n  gxr.edges().array.forEach(n=>n.properties.label = n.relationship)\n  \n}})","pinCode":false,"dname":"ea576d82-5bc8-4d3d-84d6-b5e73ef55604","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"md `---`","pinCode":false,"dname":"6ddb5bce-5986-4a85-8d5d-acd0eea20d97","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"md  `##### Trace Admin Access Paths from Users to Internet Gateways. \nCypher:\n\\`\\`\\`\nMATCH path = (u:User)-[r:ACCESS {access_level: 'admin'}]->(ig:InternetGateway)  \nRETURN u,r,ig\n\\`\\`\\`\n`","pinCode":false,"dname":"874f69b9-83ee-4e02-9b72-eefa628d1f9a","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"Inputs.button('Tracing Admin Access Paths from Users to Internet Gateways', {reduce: async ()=>{\n  await gxr.query(`MATCH path = (u:User)-[r:ACCESS {access_level: 'admin'}]->(ig:InternetGateway)\nRETURN u,r,ig`, {saveToGraph: true})\n}})","pinCode":false,"dname":"a03c7396-ac2b-4937-b767-cd952bd11f0e","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"md `<div style=\"display: flex; justify-content: space-between; font-size: 1.2em;\">\n  <a> </a>\n  <a>${Link(\"1_userAnalysis\", \"User Analysis\")}</a>\n</div>`","pinCode":false,"dname":"f6d23e27-6dde-455b-be65-00821f16b079","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"md `###### 2. Retrieve All Access Records for User (user_id=123)`","pinCode":false,"dname":"b1b0163b-94a4-4ec2-82b0-46c3810eb63e","codeMode":"javascript2","hide":true}}},{"type":"codeTool","data":{"codeData":{"value":"Inputs.button('Retrieve All Access Records for User (user_id=123)', {reduce: async ()=>{\n  await gxr.query(`MATCH (u:User)-[r:ACCESS_RECORD]->(ig:InternetGateway)\nWHERE id(u)=\"User[100]\" AND r.access_time > datetime(\"2024-12-01T00:00:00\")\nRETURN *`, {saveToGraph: true})\n}})","pinCode":false,"dname":"6b0a1357-0ab7-4a49-b6df-ae43b91b3dd0","codeMode":"javascript2","hide":true}}}],"version":"2.19.1"}