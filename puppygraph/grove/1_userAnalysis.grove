{"blocks":[{"type":"codeTool","data":{"codeData":{"value":"md`### User Analysis`","pinCode":false,"dname":"411f33dd-b4b9-496b-a3ea-266dba04b34b","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"user_data = {\n  let data = await neo4jQueryToTable(`MATCH (n:User) \nOPTIONAL MATCH (n)-[r:ACCESS_RECORD]->(ig:InternetGateway)\nWITH n, count(r) AS accessCount\nreturn n.email as email, n.username as username, n.last_login as last_login, n.failed_login_attempts as failed_login_attempts, n.account_status as account_status, accessCount`)\n  return data.map(d=>({...d, last_login: dateobj2isodate(d.last_login)}))\n}","pinCode":false,"dname":"49d73a83-5539-484f-a61b-0aa631e31243","codeMode":"javascript2","hide":true}}},{"type":"codeTool","data":{"codeData":{"value":"viewof sel_users = Inputs.table(user_data, {\n  required:false,\n  multiple: false,\n  columns:[\"username\", \"account_status\", \"accessCount\", \"failed_login_attempts\", \"last_login\", \"email\" ]\n})","pinCode":false,"dname":"c4ddc664-b650-412d-a898-79ef24487b50","codeMode":"javascript2","hide":false}}},{"type":"codeTool","data":{"codeData":{"value":"username = sel_users ? sel_users.username : \"null\"","pinCode":false,"dname":"d7028a9d-f795-4a50-81f5-9c9e7bd0b6e9","codeMode":"javascript2","hide":true}}},{"type":"codeTool","data":{"codeData":{"value":"Inputs.button(`Retrieve All Access Records for User ${username}`, {reduce: async ()=>{\n  let query = `MATCH (u:User)-[r:ACCESS_RECORD]->(ig:InternetGateway)\nWHERE u.username=\"${username}\" \nRETURN *`\n  console.log(query)\n  await gxr.query(query, {saveToGraph: true})\n  await gxr.sleep(300)\n  await expandEdge(\"ACCESS_RECORD\")\n  await gxr.sleep(300)\n  gxr.forceLayout()\n}})","pinCode":false,"dname":"3af775c9-8c61-44ed-b816-b0e31ed92601","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"md `##### Next: Plot timeline`","pinCode":false,"dname":"fb3893de-353a-4f31-aa35-cd4236a9b5b7","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"md `<div style=\"display: flex; justify-content: space-between; font-size: 1.2em;\">\n  <a>${Link(\"0_overview\", \"Overview\")} </a>\n  <a>${Link(\"2_network\", \"Network\")}</a>\n</div>`","pinCode":false,"dname":"eda9828b-71b5-434c-99d4-efe637e701eb","codeMode":"javascript2"}}},{"type":"codeTool","data":{"codeData":{"value":"md `#### Appendix`","pinCode":false,"dname":"52fce777-f2df-4a1b-ad47-9780fac6464c","codeMode":"javascript2","hide":true}}},{"type":"codeTool","data":{"codeData":{"value":"// Add SightXR group\n// Add \"Inspect\" to SightXR group\ngxr.addContextMenuItem(\n  {\n    name: 'Timeline',\n    text: 'Timeline',\n    icon: 'fa fa-clock',\n    hide: () => false,\n    enable: () => true,\n    action: (name, nodeId) => {\n      plotTimeline('access_time')\n    },\n  },\n  {\n    after: 'NodeEdgeInformation',\n  }\n);","pinCode":false,"dname":"ed32d9d9-6d6e-4b90-a8d3-7a979f746095","codeMode":"javascript2","hide":true}}},{"type":"codeTool","data":{"codeData":{"value":"dateobj2isodate = (obj)=>{\n\tlet date = new Date(obj.year.low, obj.month.low, obj.day.low, obj.hour.low, obj.minute.low, obj.second.low)\n    return date.toISOString()\n}","pinCode":false,"dname":"b820870b-c679-487d-a759-34f60f5808d1","codeMode":"javascript2","hide":true}}},{"type":"codeTool","data":{"codeData":{"value":"import {expandEdge} from 'expandEdge'","pinCode":false,"dname":"89478fa0-c716-41a3-98e6-af2534022394","codeMode":"javascript2","hide":true}}},{"type":"codeTool","data":{"codeData":{"value":"import {plotTimeline} from \"timeline\"","pinCode":false,"dname":"6bbe9eb2-c146-47f8-8e59-0d2d095a05bf","codeMode":"javascript2","hide":true}}},{"type":"codeTool","data":{"codeData":{"value":"import {neo4jQueryToTable} from 'neo4jUtilities'","pinCode":false,"dname":"ee12cec3-7cc8-427c-bdb8-4bfb86f03329","codeMode":"javascript2","hide":true}}}],"version":"2.19.1"}